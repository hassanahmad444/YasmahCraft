@model List<YasmahCraft.Models.Entities.Product>
@{
    ViewData["Title"] = "Products";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@if (TempData["Success"] != null)
{
    <div class="alert-craft">
        <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
    </div>
}

<div class="section-header">
    <div>
        <div style="font-size:20px; font-weight:700; color:#2c1a0e;">Products</div>
        <div style="font-size:13px; color:#9c7b6a; margin-top:2px;">Manage your crochet pieces</div>
    </div>
    <a href="/Admin/CreateProduct" class="btn-terra">
        <i class="bi bi-plus-lg"></i> Add Product
    </a>
</div>

<div class="admin-card">
    @if (Model == null || !Model.Any())
    {
        <div style="text-align:center; padding:48px 0; color:#9c7b6a;">
            <i class="bi bi-bag-x" style="font-size:48px; display:block; margin-bottom:16px; opacity:0.3;"></i>
            <div style="font-size:15px; font-weight:600; color:#2c1a0e;">No products yet</div>
            <div style="font-size:13px; margin-top:4px;">Add your first product to get started</div>
        </div>
    }
    else
    {
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Product</th>
                    <th>Category</th>
                    <th>Price</th>
                    <th>Stock</th>
                    <th>Status</th>
                    <th style="text-align:right;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var product in Model)
                {
                    <tr>
                        <td>
                            <div style="font-weight:600; color:#2c1a0e;">@product.Name</div>
                            @if (!string.IsNullOrEmpty(product.Colour))
                            {
                                <div style="font-size:12px; color:#9c7b6a;">@product.Colour</div>
                            }
                        </td>
                        <td style="color:#6b4c3b;">@product.Category?.Name</td>
                        <td style="font-weight:600; color:#c4714a;">₦@product.Price.ToString("N0")</td>
                        <td>@product.StockQuantity</td>
                        <td>
                            @if (product.IsAvailable && product.StockQuantity > 0)
                            {
                                <span class="badge-status badge-shipped">Available</span>
                            }
                            else
                            {
                                <span class="badge-status badge-cancelled">Unavailable</span>
                            }
                        </td>
                        <td style="text-align:right;">
                            <div style="display:flex; gap:8px; justify-content:flex-end;">
                                <a href="/Admin/EditProduct/@product.Id" class="btn-outline-terra" style="padding:5px 12px; font-size:12px;">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>
                                <form asp-action="DeleteProduct" asp-controller="Admin" method="post"
                                      style="display:inline;"
                                      onsubmit="return confirm('Delete @product.Name?')">
                                    <input type="hidden" name="id" value="@product.Id" />
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn-danger-sm">
                                        <i class="bi bi-trash3"></i> Delete
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
