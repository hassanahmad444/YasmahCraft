@model List<YasmahCraft.Models.Entities.Order>
@{
    ViewData["Title"] = "Orders";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="section-header">
    <div>
        <div style="font-size:20px; font-weight:700; color:#2c1a0e;">Orders</div>
        <div style="font-size:13px; color:#9c7b6a; margin-top:2px;">All customer orders</div>
    </div>
</div>

<div class="admin-card">
    @if (Model == null || !Model.Any())
    {
        <div style="text-align:center; padding:48px 0; color:#9c7b6a;">
            <i class="bi bi-receipt" style="font-size:48px; display:block; margin-bottom:16px; opacity:0.3;"></i>
            <div style="font-size:15px; font-weight:600; color:#2c1a0e;">No orders yet</div>
            <div style="font-size:13px; margin-top:4px;">Orders will appear here when customers make purchases</div>
        </div>
    }
    else
    {
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Order No.</th>
                    <th>Customer</th>
                    <th>Phone</th>
                    <th>Amount</th>
                    <th>Status</th>
                    <th>Date</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model)
                {
                    <tr>
                        <td style="font-weight:700; color:#c4714a; font-family:'Cormorant Garamond',serif; font-size:16px;">
                            @order.OrderNumber
                        </td>
                        <td>
                            <div style="font-weight:600; color:#2c1a0e;">@order.CustomerName</div>
                            <div style="font-size:12px; color:#9c7b6a;">@order.CustomerEmail</div>
                        </td>
                        <td style="color:#6b4c3b;">@order.CustomerPhone</td>
                        <td style="font-weight:700; color:#c4714a;">₦@order.TotalAmount.ToString("N0")</td>
                        <td>
                            @switch (order.Status)
                            {
                                case YasmahCraft.Models.Entities.OrderStatus.Pending:
                                    <span class="badge-status badge-pending">Pending</span>
                                    break;
                                case YasmahCraft.Models.Entities.OrderStatus.Confirmed:
                                    <span class="badge-status badge-confirmed">Confirmed</span>
                                    break;
                                case YasmahCraft.Models.Entities.OrderStatus.Shipped:
                                    <span class="badge-status badge-shipped">Shipped</span>
                                    break;
                                case YasmahCraft.Models.Entities.OrderStatus.Delivered:
                                    <span class="badge-status badge-delivered">Delivered</span>
                                    break;
                                case YasmahCraft.Models.Entities.OrderStatus.Cancelled:
                                    <span class="badge-status badge-cancelled">Cancelled</span>
                                    break;
                            }
                        </td>
                        <td style="color:#9c7b6a; font-size:12px;">@order.OrderDate.ToLocalTime().ToString("dd MMM yyyy")</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>