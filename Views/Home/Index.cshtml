@{
    ViewData["Title"] = "Home Page";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- HERO -->
<section style="background: linear-gradient(135deg, #f5ede6 0%, #f7eeec 100%); padding: 100px 40px; text-align: center; position: relative; overflow: hidden;">
    <div style="position:absolute; top:-100px; right:-100px; width:400px; height:400px; background:radial-gradient(circle, rgba(196,113,74,0.08) 0%, transparent 70%); border-radius:50%;"></div>
    <div style="position:absolute; bottom:-80px; left:-80px; width:300px; height:300px; background:radial-gradient(circle, rgba(212,148,138,0.08) 0%, transparent 70%); border-radius:50%;"></div>
    
    <div style="position:relative; max-width:700px; margin:0 auto;">
        <div style="font-size:11px; font-weight:600; letter-spacing:4px; text-transform:uppercase; color:#c4714a; margin-bottom:16px;">
            ✦ Handcrafted with Love ✦
        </div>
        <h1 style="font-family:'Cormorant Garamond',serif; font-size:68px; font-weight:600; color:#2c1a0e; line-height:1.1; margin-bottom:20px;">
            Wear the Art of <em style="color:#c4714a; font-style:italic;">Crochet</em>
        </h1>
        <p style="font-size:16px; color:#9c7b6a; max-width:480px; margin:0 auto 36px; line-height:1.8; font-weight:300;">
            Every piece is carefully handcrafted by Yasmah — unique crochet bags and clothing made for women who appreciate artisan fashion.
        </p>
        <div style="display:flex; gap:16px; justify-content:center; flex-wrap:wrap;">
            <a href="/Shop" class="btn-terra">
                <i class="bi bi-bag-fill"></i> Shop Collection
            </a>
            <a href="https://wa.me/2347036832309" class="whatsapp-btn">
                <i class="bi bi-whatsapp"></i> Order via WhatsApp
            </a>
        </div>
    </div>
</section>

<!-- CATEGORIES -->
<section style="padding: 80px 40px; max-width:1200px; margin:0 auto;">
    <div style="text-align:center; margin-bottom:48px;">
        <div class="section-eyebrow">Browse by Category</div>
