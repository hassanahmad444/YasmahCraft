@{
    ViewData["Title"] = "Home Page";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- HERO SLIDESHOW -->
<section style="position:relative; width:100%; height:85vh; overflow:hidden; background:#0F0F0F;">

    <style>
        .slide{position:absolute;inset:0;opacity:0;transition:opacity 1.2s ease}
        .slide.active{opacity:1}
        .slide-img{position:absolute;inset:0;overflow:hidden}
        .slide-img img{width:100%;height:100%;object-fit:cover;transition:transform 7s ease}
        .slide.active .slide-img img{transform:scale(1.04)}
        .slide-overlay{position:absolute;inset:0;background:linear-gradient(90deg,rgba(15,15,15,0.85) 0%,rgba(15,15,15,0.45) 60%,rgba(15,15,15,0.1) 100%)}
        .slide-content{position:absolute;inset:0;display:flex;align-items:center;padding:0 7%;z-index:2}
        .slide-text{max-width:480px}
        .slide-eyebrow{font-size:11px;letter-spacing:4px;text-transform:uppercase;color:#D4AF37;margin-bottom:18px;font-family:'Jost',sans-serif}
        .slide-title{font-size:52px;font-weight:400;color:#ffffff;line-height:1.1;margin-bottom:16px;font-family:'Cormorant Garamond',serif}
        .slide-title em{color:#D4AF37;font-style:italic}
        .slide-sub{font-size:15px;color:rgba(255,255,255,0.7);line-height:1.7;margin-bottom:32px;font-family:'Jost',sans-serif;font-weight:300;max-width:360px}
        .slide-badge{display:inline-block;background:#D4AF37;color:#0F0F0F;font-size:11px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;padding:6px 14px;margin-bottom:20px;font-family:'Jost',sans-serif}
        .hero-btn-primary{display:inline-flex;align-items:center;gap:8px;background:#D4AF37;color:#0F0F0F;border:none;padding:14px 28px;font-size:12px;font-weight:700;letter-spacing:2px;text-transform:uppercase;cursor:pointer;transition:all 0.25s;font-family:'Jost',sans-serif;text-decoration:none}
        .hero-btn-primary:hover{background:#ffffff;color:#0F0F0F;transform:translateY(-2px)}
        .hero-btn-secondary{display:inline-flex;align-items:center;gap:8px;background:transparent;color:#ffffff;border:1px solid rgba(255,255,255,0.5);padding:14px 28px;font-size:12px;font-weight:600;letter-spacing:2px;text-transform:uppercase;cursor:pointer;transition:all 0.25s;font-family:'Jost',sans-serif;text-decoration:none}
        .hero-btn-secondary:hover{border-color:#D4AF37;color:#D4AF37}
        .hero-btns{display:flex;gap:12px;flex-wrap:wrap}
        .hero-nav{position:absolute;bottom:28px;left:7%;display:flex;align-items:center;gap:16px;z-index:10}
        .hero-dot{width:24px;height:2px;background:rgba(255,255,255,0.35);cursor:pointer;transition:all 0.3s}
        .hero-dot.active{width:40px;background:#D4AF37}
        .hero-arrows{position:absolute;right:7%;bottom:22px;display:flex;gap:8px;z-index:10}
        .hero-arrow{width:44px;height:44px;border:1px solid rgba(255,255,255,0.3);background:transparent;color:white;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:18px;transition:all 0.2s}
        .hero-arrow:hover{border-color:#D4AF37;color:#D4AF37}
        .hero-count{position:absolute;top:32px;right:7%;font-size:12px;color:rgba(255,255,255,0.4);letter-spacing:2px;font-family:'Jost',sans-serif;z-index:10}
        .hero-progress{position:absolute;bottom:0;left:0;height:2px;background:#D4AF37;width:0%;z-index:10}

        @@media(max-width:768px){
            .slide-title{font-size:34px}
            .slide-sub{font-size:13px;max-width:100%}
            .slide-eyebrow{font-size:9px;margin-bottom:10px}
            .slide-badge{font-size:9px;padding:5px 10px;margin-bottom:12px}
            .slide-content{padding:0 24px;align-items:flex-end;padding-bottom:80px}
            .hero-btn-primary,.hero-btn-secondary{padding:11px 18px;font-size:10px;letter-spacing:1px}
            .hero-arrows{display:none}
            .hero-count{top:20px;right:20px}
            .hero-nav{bottom:20px;left:24px}
            .slide-overlay{background:linear-gradient(0deg,rgba(15,15,15,0.88) 0%,rgba(15,15,15,0.3) 60%,transparent 100%)}
        }
    </style>

    <!-- SLIDE 1 -->
    <div class="slide active">
        <div class="slide-img">
            <img src="https://i.ibb.co/8D6JshxW/94b2435c6434fa78f57527e3955779bd.jpg" alt="Slide 1" style="object-position:center top;" />
        </div>
        <div class="slide-overlay"></div>
        <div class="slide-content">
            <div class="slide-text">
                <div class="slide-badge">New Collection 2026</div>
                <div class="slide-eyebrow">Handcrafted with love</div>
                <h1 class="slide-title">Wear the Art<br>of <em>Crochet</em></h1>
                <p class="slide-sub">Unique pieces crafted stitch by stitch — for women who appreciate true artisan fashion.</p>
                <div class="hero-btns">
                    <a href="/Shop" class="hero-btn-primary">Shop Collection</a>
                    <a href="https://wa.me/2347036832309" class="hero-btn-secondary">Order via WhatsApp</a>
                </div>
            </div>
        </div>
    </div>

    <!-- SLIDE 2 -->
    <div class="slide">
        <div class="slide-img">
            <img src="https://i.ibb.co/vvVk0H2H/fad2fe6b91ab86d3d0d4948d12f17638.jpg" alt="Slide 2" />
        </div>
        <div class="slide-overlay"></div>
        <div class="slide-content">
            <div class="slide-text">
                <div class="slide-badge">Co-ord Sets</div>
                <div class="slide-eyebrow">Clothing collection</div>
                <h1 class="slide-title">Bold, Beautiful<br><em>& Handmade</em></h1>
                <p class="slide-sub">Statement co-ord sets crafted for every occasion — from birthdays to photoshoots.</p>
                <div class="hero-btns">
                    <a href="/Shop?category=Clothing" class="hero-btn-primary">Shop Clothing</a>
                    <a href="https://wa.me/2347036832309" class="hero-btn-secondary">Custom Order</a>
                </div>
            </div>
        </div>
    </div>

    <!-- SLIDE 3 -->
    <div class="slide">
        <div class="slide-img">
            <img src="https://i.ibb.co/yF9Hjtg8/33be8a24b238fd3544e14dc32ac63861.jpg" alt="Slide 3" />
        </div>
        <div class="slide-overlay"></div>
        <div class="slide-content">
            <div class="slide-text">
                <div class="slide-badge">Bags Collection</div>
                <div class="slide-eyebrow">Premium crochet bags</div>
                <h1 class="slide-title">Carry Art<br><em>Everywhere</em></h1>
                <p class="slide-sub">Handwoven bags that turn heads — totes, backpacks, clutches crafted to last.</p>
                <div class="hero-btns">
                    <a href="/Shop?category=Bags" class="hero-btn-primary">Shop Bags</a>
                    <a href="https://wa.me/2347036832309" class="hero-btn-secondary">WhatsApp Us</a>
                </div>
            </div>
        </div>
    </div>

    <!-- SLIDE 4 -->
    <div class="slide">
        <div class="slide-img">
            <img src="https://i.ibb.co/4Z4kfYt3/52729511d9236c7ee005d606482170c8.jpg" alt="Slide 4" />
        </div>
        <div class="slide-overlay"></div>
        <div class="slide-content">
            <div class="slide-text">
                <div class="slide-badge">Sweaters & Knitwear</div>
                <div class="slide-eyebrow">Stay cosy in style</div>
                <h1 class="slide-title">Colour, Warmth<br><em>& Character</em></h1>
                <p class="slide-sub">Vibrant handcrafted sweaters made for women who refuse to blend in.</p>
                <div class="hero-btns">
                    <a href="/Shop?category=Clothing" class="hero-btn-primary">Shop Now</a>
                    <a href="https://wa.me/2347036832309" class="hero-btn-secondary">Order Custom</a>
                </div>
            </div>
        </div>
    </div>

    <div class="hero-count"><span id="heroCurr">01</span> / 04</div>
    <div class="hero-progress" id="heroProgress"></div>
    <div class="hero-nav">
        <div class="hero-dot active" onclick="heroGoTo(0)"></div>
        <div class="hero-dot" onclick="heroGoTo(1)"></div>
        <div class="hero-dot" onclick="heroGoTo(2)"></div>
        <div class="hero-dot" onclick="heroGoTo(3)"></div>
    </div>
    <div class="hero-arrows">
        <button class="hero-arrow" onclick="heroPrev()">&#8592;</button>
        <button class="hero-arrow" onclick="heroNext()">&#8594;</button>
    </div>
</section>

