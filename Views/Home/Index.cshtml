<script>
    let heroCur=0,heroTot=4,heroProgVal=0,heroProgTimer;
    const heroSlides=document.querySelectorAll('.slide');
    const heroDots=document.querySelectorAll('.hero-dot');
    const heroCurrEl=document.getElementById('heroCurr');
    const heroProgEl=document.getElementById('heroProgress');

    function heroGoTo(n){
        heroSlides[heroCur].classList.remove('active');
        heroDots[heroCur].classList.remove('active');
        heroCur=n;
        heroSlides[heroCur].classList.add('active');
        heroDots[heroCur].classList.add('active');
        heroCurrEl.textContent=String(heroCur+1).padStart(2,'0');
        heroResetProg();
    }

    function heroNext(){heroGoTo((heroCur+1)%heroTot)}
    function heroPrev(){heroGoTo((heroCur-1+heroTot)%heroTot)}

    function heroResetProg(){
        clearInterval(heroProgTimer);
        heroProgVal=0;
        heroProgEl.style.width='0%';
        heroProgTimer=setInterval(()=>{
            heroProgVal+=0.33;
            heroProgEl.style.width=heroProgVal+'%';
            if(heroProgVal>=100){clearInterval(heroProgTimer);heroNext()}
        },33);
    }

    heroResetProg();
</script>