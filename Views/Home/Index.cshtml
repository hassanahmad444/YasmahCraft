        <div class="section-divider" style="margin:16px auto 0;"></div>
    </div>

    <div style="display:grid; grid-template-columns:1fr 1fr; gap:24px;">
        <a href="/Shop" class="category-card" style="text-decoration:none;">
            <div style="width:100%; height:100%; background:linear-gradient(135deg, #f5ede6, #e8d0c0); display:flex; align-items:center; justify-content:center; min-height:300px;">
                <i class="bi bi-handbag-fill" style="font-size:80px; color:#c4714a; opacity:0.4;"></i>
            </div>
            <div class="category-overlay">
                <div>
                    <div class="category-name">Bags</div>
                    <div style="font-size:12px; color:rgba(255,255,255,0.7); margin-top:4px; font-family:'Jost',sans-serif;">Tote bags, clutches & more</div>
                </div>
            </div>
        </a>

        <a href="/Shop" class="category-card" style="text-decoration:none;">
            <div style="width:100%; height:100%; background:linear-gradient(135deg, #f7eeec, #e8d4d0); display:flex; align-items:center; justify-content:center; min-height:300px;">
                <i class="bi bi-person-fill" style="font-size:80px; color:#d4948a; opacity:0.4;"></i>
            </div>
            <div class="category-overlay">
                <div>
                    <div class="category-name">Clothing</div>
                    <div style="font-size:12px; color:rgba(255,255,255,0.7); margin-top:4px; font-family:'Jost',sans-serif;">Tops, dresses & sets</div>
                </div>
            </div>
        </a>
    </div>
</section>

