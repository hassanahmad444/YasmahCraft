@{
    ViewData["Title"] = "About Us";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .about-hero {
        background: linear-gradient(135deg, #f5ede6, #f7eeec);
        padding: 80px 40px;
        text-align: center;
    }

    .about-story {
        max-width: 900px;
        margin: 0 auto;
        padding: 80px 40px;
    }

    .about-story-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 64px;
        align-items: center;
    }

    .about-story-img {
        width: 100%;
        aspect-ratio: 3/4;
        object-fit: cover;
        border-radius: 4px;
        display: block;
    }

    .values-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 32px;
    }

    .cta-btns {
        display: flex;
        gap: 16px;
        justify-content: center;
        flex-wrap: wrap;
    }

    @@media(max-width: 768px) {
        .about-hero {
            padding: 56px 24px;
        }

        .about-hero h1 {
            font-size: 36px !important;
        }

        .about-story {
            padding: 48px 24px;
        }

        .about-story-grid {
            grid-template-columns: 1fr;
            gap: 36px;
        }

        .about-story-img {
            aspect-ratio: 4/3;
            order: -1;
        }

        .values-grid {
            grid-template-columns: 1fr;
            gap: 0;
        }

        .values-grid > div {
            border-bottom: 1px solid rgba(255,255,255,0.07);
            padding: 28px 16px !important;
        }

        .values-grid > div:last-child {
            border-bottom: none;
        }

        .cta-btns .btn-terra,
        .cta-btns .whatsapp-btn {
            width: 100%;
            justify-content: center;
        }
    }
</style>

<!-- HERO -->
<section class="about-hero">
    <div style="font-size:10px; font-weight:600; letter-spacing:4px; text-transform:uppercase; color:#c4714a; margin-bottom:8px;">
        Our Story
    </div>
    <h1 style="font-family:'Cormorant Garamond',serif; font-size:52px; font-weight:600; color:#2c1a0e; line-height:1.2;">
        About Yasmah Craft
    </h1>
    <p style="font-size:15px; color:#9c7b6a; max-width:500px; margin:16px auto 0; line-height:1.8; font-weight:300;">
        A passion for crochet turned into a brand — handcrafted with love, creativity, and dedication to quality.
    </p>
</section>

<!-- STORY -->
<section class="about-story">
    <div class="about-story-grid">
        <div>
            <div style="font-size:10px; font-weight:600; letter-spacing:4px; text-transform:uppercase; color:#c4714a; margin-bottom:12px;">
                Who We Are
            </div>
            <h2 style="font-family:'Cormorant Garamond',serif; font-size:36px; font-weight:600; color:#2c1a0e; line-height:1.3; margin-bottom:20px;">
                Every Stitch Tells a Story
            </h2>
            <p style="font-size:14px; color:#6b4c3b; line-height:1.9; margin-bottom:16px; font-weight:300;">
                Yasmah Craft was born from a deep love for the art of crochet. What started as a hobby quickly became a calling — creating beautiful, wearable pieces that celebrate femininity, culture, and craftsmanship.
            </p>
            <p style="font-size:14px; color:#6b4c3b; line-height:1.9; font-weight:300;">
                Every bag, every top, every set is made by hand with premium yarn and attention to detail. No mass production, no shortcuts — just genuine handmade artisan fashion created with love.
            </p>
        </div>
        <img src="https://i.ibb.co/MDTKzTBS/246db56ca39f4763ad2171738d34143a.jpg" alt="About Yasmah" class="about-story-img" />
    </div>
</section>

<!-- VALUES -->
<section style="background:#2c1a0e; padding:80px 40px;">
    <div style="max-width:900px; margin:0 auto; text-align:center;">
        <div style="font-size:10px; font-weight:600; letter-spacing:4px; text-transform:uppercase; color:#c4714a; margin-bottom:8px;">
            What We Stand For
        </div>
        <h2 style="font-family:'Cormorant Garamond',serif; font-size:40px; font-weight:600; color:white; margin-bottom:48px;">
            Our Values
        </h2>
        <div class="values-grid">
            <div style="padding:24px;">
                <i class="bi bi-hand-thumbs-up-fill" style="font-size:32px; color:#c4714a; display:block; margin-bottom:16px;"></i>
                <h3 style="font-family:'Cormorant Garamond',serif; font-size:22px; color:white; margin-bottom:12px;">Quality First</h3>
                <p style="font-size:13px; color:rgba(255,255,255,0.5); line-height:1.8; font-weight:300;">We never compromise on materials or craftsmanship. Every piece meets our high standards before it reaches you.</p>
            </div>
            <div style="padding:24px;">
                <i class="bi bi-person-heart" style="font-size:32px; color:#c4714a; display:block; margin-bottom:16px;"></i>
                <h3 style="font-family:'Cormorant Garamond',serif; font-size:22px; color:white; margin-bottom:12px;">Customer Love</h3>
                <p style="font-size:13px; color:rgba(255,255,255,0.5); line-height:1.8; font-weight:300;">Your satisfaction is everything to us. We're always available on WhatsApp to help you find your perfect piece.</p>
            </div>
            <div style="padding:24px;">
                <i class="bi bi-stars" style="font-size:32px; color:#c4714a; display:block; margin-bottom:16px;"></i>
                <h3 style="font-family:'Cormorant Garamond',serif; font-size:22px; color:white; margin-bottom:12px;">Unique Pieces</h3>
                <p style="font-size:13px; color:rgba(255,255,255,0.5); line-height:1.8; font-weight:300;">No two pieces are exactly alike. When you wear Yasmah Craft, you wear something truly one of a kind.</p>
            </div>
        </div>
    </div>
</section>

<!-- CTA -->
<section style="padding:80px 40px; text-align:center;">
    <div style="max-width:500px; margin:0 auto;">
        <h2 style="font-family:'Cormorant Garamond',serif; font-size:40px; font-weight:600; color:#2c1a0e; margin-bottom:16px;">
            Ready to Shop?
        </h2>
        <p style="font-size:14px; color:#9c7b6a; margin-bottom:32px; font-weight:300; line-height:1.8;">
            Browse our latest collection of handcrafted crochet pieces.
        </p>
        <div class="cta-btns">
            <a href="/Shop" class="btn-terra" style="width:auto;">
                <i class="bi bi-bag-fill"></i> Shop Now
            </a>
            <a href="https://wa.me/2347036832309" class="whatsapp-btn" style="width:auto;">
                <i class="bi bi-whatsapp"></i> Contact Us
            </a>
        </div>
    </div>
</section>
