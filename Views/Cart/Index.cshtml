@model List<YasmahCraft.Models.CartItem>
@{
    ViewData["Title"] = "Your Cart";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .cart-container {
        max-width: 900px;
        margin: 0 auto;
        padding: 48px 40px;
    }

    .cart-item-row {
        display: flex;
        gap: 16px;
        align-items: center;
        background: white;
        border: 1px solid #e8d8cc;
        border-radius: 4px;
        padding: 16px;
        margin-bottom: 16px;
    }

    .cart-item-img {
        width: 80px;
        height: 80px;
        border-radius: 4px;
        overflow: hidden;
        background: #f5ede6;
        flex-shrink: 0;
    }

        .cart-item-img img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .cart-item-info {
        flex: 1;
        min-width: 0;
    }

    .cart-qty-form {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .cart-qty-input {
        width: 50px;
        text-align: center;
        border: 1px solid #e8d8cc;
        border-radius: 2px;
        padding: 6px 4px;
        font-size: 13px;
        font-family: 'Jost', sans-serif;
    }

    .cart-summary {
        background: white;
        border: 1px solid #e8d8cc;
        border-radius: 4px;
        padding: 24px;
        margin-top: 24px;
    }

    @@media(max-width: 768px) {
        .cart-container {
            padding: 24px 20px;
        }

            .cart-container h1 {
                font-size: 32px !important;
            }

        .cart-item-row {
            flex-wrap: wrap;
        }

        .cart-item-img {
            width: 64px;
            height: 64px;
        }

        .cart-item-actions {
            width: 100%;
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 8px;
        }
    }
</style>

<div class="cart-container">
    <div style="text-align:center; margin-bottom:40px;">
        <div style="font-size:10px; font-weight:600; letter-spacing:4px; text-transform:uppercase; color:#c4714a; margin-bottom:8px;">
            Your Selection
        </div>
        <h1 style="font-family:'Cormorant Garamond',serif; font-size:42px; font-weight:600; color:#2c1a0e;">
            Your Cart
        </h1>
    </div>

    @if (TempData["CartMessage"] != null)
    {
        <div class="alert-craft">
            <i class="bi bi-check-circle-fill"></i> @TempData["CartMessage"]
        </div>
    }

    @if (Model == null || !Model.Any())
    {
        <div style="text-align:center; padding:60px 0;">
            <i class="bi bi-cart-x" style="font-size:64px; color:#e8d8cc; display:block; margin-bottom:24px;"></i>
            <h3 style="font-family:'Cormorant Garamond',serif; font-size:24px; color:#2c1a0e; margin-bottom:12px;">Your cart is empty</h3>
            <p style="font-size:14px; color:#9c7b6a; margin-bottom:32px; font-weight:300;">Browse our collection and add items you love.</p>
            <a href="/Shop" class="btn-terra" style="width:auto;">
                <i class="bi bi-bag-fill"></i> Start Shopping
            </a>
        </div>
    }
    else
    {
        @foreach (var item in Model)
        {
            <div class="cart-item-row">
                <div class="cart-item-img">
                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                    {
                        <img src="@item.ImageUrl" alt="@item.ProductName" />
                    }
                    else
                    {
                        <div style="width:100%; height:100%; display:flex; align-items:center; justify-content:center;">
                            <i class="bi bi-image" style="font-size:24px; color:#e8d8cc;"></i>
                        </div>
                    }
                </div>
                <div class="cart-item-info">
                    <div style="font-family:'Cormorant Garamond',serif; font-size:18px; font-weight:600; color:#2c1a0e;">@item.ProductName</div>
                    <div style="font-size:12px; color:#9c7b6a; margin:2px 0 6px;">Size: @item.Size</div>
                    <div style="font-size:15px; font-weight:700; color:#c4714a;">₦@item.UnitPrice.ToString("N0")</div>
                </div>
                <div class="cart-item-actions" style="display:flex; align-items:center; gap:12px;">
                    <form asp-action="UpdateQuantity" asp-controller="Cart" method="post" class="cart-qty-form">
                        <input type="hidden" name="productId" value="@item.ProductId" />
                        <input type="hidden" name="size" value="@item.Size" />
                        <input type="number" name="quantity" value="@item.Quantity" min="1" class="cart-qty-input" onchange="this.form.submit()" />
                    </form>
                    <form asp-action="Remove" asp-controller="Cart" method="post">
                        <input type="hidden" name="productId" value="@item.ProductId" />
                        <input type="hidden" name="size" value="@item.Size" />
                        <button type="submit" class="btn-danger-sm">
                            <i class="bi bi-trash"></i>
                        </button>
                    </form>
                </div>
            </div>
        }

        <div class="cart-summary">
            <div style="display:flex; justify-content:space-between; font-size:18px; font-weight:700; color:#2c1a0e;">
                <span>Total</span>
                <span style="color:#c4714a;">₦@Model.Sum(i => i.TotalPrice).ToString("N0")</span>
            </div>
        </div>

        <div style="display:flex; gap:16px; margin-top:24px; flex-wrap:wrap;">
            <a href="/Shop" class="btn-outline-terra" style="width:auto;">
                <i class="bi bi-arrow-left"></i> Continue Shopping
            </a>
            <a href="/Order/CheckoutCart" class="btn-terra" style="width:auto; flex:1; justify-content:center;">
                <i class="bi bi-credit-card-fill"></i> Proceed to Checkout
            </a>
        </div>
    }
</div>