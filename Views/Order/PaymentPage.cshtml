@model YasmahCraft.ViewModels.PlaceOrderViewModel
@{
    ViewData["Title"] = "Payment";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var publicKey = ViewBag.PublicKey as string;
    var reference = ViewBag.Reference as string;
    var amount = (int)ViewBag.Amount;
    var email = ViewBag.Email as string;
    var orderNumber = ViewBag.OrderNumber as string;
}

<style>
    .payment-container {
        max-width: 600px;
        margin: 0 auto;
        padding: 80px 40px;
        text-align: center;
    }

    .payment-detail-row {
        display: flex;
        justify-content: space-between;
        margin-bottom: 12px;
        font-size: 14px;
        flex-wrap: wrap;
        gap: 4px;
    }

    @@media(max-width: 768px) {
        .payment-container {
            padding: 48px 20px;
        }

        .payment-container h1 {
            font-size: 32px !important;
        }

        .pay-btn {
            width: 100% !important;
            justify-content: center !important;
        }
    }
</style>

<div class="payment-container">
    <div style="width:80px; height:80px; background:#f5ede6; border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 24px; font-size:36px; color:#c4714a;">
        <i class="bi bi-credit-card-fill"></i>
    </div>
    <div style="font-size:10px; font-weight:600; letter-spacing:4px; text-transform:uppercase; color:#c4714a; margin-bottom:8px;">
        Final Step
    </div>
    <h1 style="font-family:'Cormorant Garamond',serif; font-size:42px; font-weight:600; color:#2c1a0e; margin-bottom:16px;">
        Complete Payment
    </h1>
    <div style="background:white; border:1px solid #e8d8cc; border-radius:4px; padding:24px; margin:32px 0; text-align:left;">
        <div class="payment-detail-row">
            <span style="color:#9c7b6a;">Order Number</span>
            <span style="font-weight:700; color:#2c1a0e; font-family:'Cormorant Garamond',serif; font-size:16px;">@orderNumber</span>
        </div>
        <div class="payment-detail-row">
            <span style="color:#9c7b6a;">Customer</span>
            <span style="font-weight:600; color:#2c1a0e;">@Model.CustomerName</span>
        </div>
        <div class="payment-detail-row">
            <span style="color:#9c7b6a;">Email</span>
            <span style="font-weight:600; color:#2c1a0e; word-break:break-all;">@Model.CustomerEmail</span>
        </div>
        <div style="border-top:1px solid #e8d8cc; margin-top:16px; padding-top:16px; display:flex; justify-content:space-between;">
            <span style="font-size:15px; font-weight:700; color:#2c1a0e;">Total Amount</span>
            <span style="font-size:20px; font-weight:800; color:#c4714a;">₦@Model.CartItems.Sum(i => i.TotalPrice).ToString("N0")</span>
        </div>
    </div>
    <button onclick="payWithPaystack()" class="btn-terra pay-btn" style="width:100%; justify-content:center; padding:16px; font-size:15px; border-radius:4px;">
        <i class="bi bi-lock-fill"></i> Pay ₦@Model.CartItems.Sum(i => i.TotalPrice).ToString("N0") Securely
    </button>
    <div style="margin-top:20px; display:flex; align-items:center; justify-content:center; gap:8px; font-size:12px; color:#9c7b6a;">
        <i class="bi bi-shield-check" style="color:#c4714a;"></i>
        Secured by Paystack
    </div>
</div>

@section Scripts {
    <script src="https://js.paystack.co/v1/inline.js"></script>
    <script>
        function payWithPaystack() {
            var handler = PaystackPop.setup({
                key: '@publicKey',
                email: '@email',
                amount: @amount,
                ref: '@reference',
                currency: 'NGN',
                callback: function(response) {
                    window.location.href = '/Order/VerifyPayment?reference=' + response.reference;
                },
                onClose: function() {
                    alert('Payment window closed. Your order is saved — you can complete payment later.');
                }
            });
            handler.openIframe();
        }
    </script>
}
